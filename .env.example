# -----------------------------------------------------------------------------
# Eazi Cut — Environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development, and set each var in
# Vercel's Project Settings → Environment Variables for preview and production.
# `.env*` files are gitignored except this template.


# -----------------------------------------------------------------------------
# Paystack (required for /checkout)
# -----------------------------------------------------------------------------
# The Paystack public key. Safe to expose to the browser — this is what the
# NEXT_PUBLIC_ prefix means. NEVER expose the *secret* key here.
#
# Get yours at: https://dashboard.paystack.com/#/settings/developers
#
# Test key format:  pk_test_...
# Live key format:  pk_live_...   (production only — Vercel Production scope)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_me
